<%- include("partials/app-shell-start") %>
<section class="page-head">
  <div>
    <h2>Finance Dashboard</h2>
    <p class="subtle">Finance gets a tighter review queue, compact summaries, and a consistent view of the latest reimbursement movement.</p>
  </div>
  <div class="role-chip">Finance View</div>
</section>

<section class="stats-row">
  <div class="stat-card"><span>Approved</span><strong><%= stats.summary.approved_count || 0 %></strong></div>
  <div class="stat-card"><span>Rejected</span><strong><%= stats.summary.rejected_count || 0 %></strong></div>
  <div class="stat-card"><span>Pending</span><strong><%= stats.summary.pending_count || 0 %></strong></div>
  <div class="stat-card"><span>Total Spend</span><strong><%= companyCurrency %> <%= stats.summary.total_spend || 0 %></strong></div>
</section>

<section class="dashboard-grid finance-grid">
  <div class="panel">
    <div class="section-head"><strong>Finance Review Queue</strong><span class="subtle">Top 5 pending items</span></div>
    <div class="queue">
      <% if (!reviewQueue.length) { %>
        <p class="subtle">No finance approvals pending.</p>
      <% } %>
      <% reviewQueue.forEach((claim) => { %>
        <article class="queue-card">
          <div class="timeline-row">
            <strong><%= claim.employee_name %></strong>
            <span class="pill pill-<%= claim.status %>"><%= claim.status_label %></span>
          </div>
          <div class="compact-meta">
            <span><strong><%= claim.category_name %></strong></span>
            <span><strong><%= claim.reported_currency %> <%= claim.amount %></strong></span>
            <span class="subtle"><%= claim.department_name || 'No Department' %></span>
            <span class="subtle">Risk <%= claim.risk_score %></span>
          </div>
          <div class="actions compact-actions">
            <form action="/reviews/<%= claim.id %>/approve" method="post">
              <button type="submit">Approve</button>
            </form>
            <form action="/reviews/<%= claim.id %>/reject" method="post">
              <input type="hidden" name="comment" value="Finance rejected" />
              <button type="submit" class="ghost">Reject</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
  <div class="panel">
    <div class="section-head"><strong>Aggregate Reimbursement Value</strong><span class="subtle">Top 5 departments</span></div>
    <% stats.departmentSpend.forEach((item) => { %>
      <div class="meter-row">
        <span><%= item.name %></span>
        <div class="meter"><div class="meter-fill" style="width: <%= Math.min(Number(item.total || 0) / 15, 100) %>%"></div></div>
        <strong><%= companyCurrency %> <%= item.total %></strong>
      </div>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Finance Review Feed</strong><span class="subtle">Top 5 latest claims</span></div>
  <div class="queue">
    <% financeQueue.forEach((claim) => { %>
      <article class="queue-card">
        <div class="timeline-row">
          <strong><%= claim.employee_name %></strong>
          <span class="pill pill-<%= claim.status %>"><%= claim.status_label %></span>
        </div>
        <div class="compact-meta">
          <span><strong><%= claim.category_name %></strong></span>
          <span><strong><%= claim.reported_currency %> <%= claim.amount %></strong></span>
          <span class="subtle"><%= claim.department_name || 'No Department' %></span>
          <span class="badge <%= claim.ai_summary === 'Authentic' ? 'badge-success' : 'badge-danger' %>"><%= claim.ai_summary %></span>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Finance History</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% historyFeed.forEach((item) => { %>
      <div class="log-row">
        <span><strong><%= item.title %></strong> - <%= item.detail %></span>
        <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
      </div>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Notifications</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% notifications.forEach((notice) => { %>
      <div class="log-row">
        <span><strong><%= notice.title %></strong> - <%= notice.body %></span>
        <small><%= notice.created_at.toISOString().slice(0, 16).replace("T", " ") %></small>
      </div>
    <% }) %>
  </div>
</section>
<%- include("partials/app-shell-end") %>
