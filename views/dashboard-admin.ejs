<%- include("partials/app-shell-start") %>
<section class="page-head">
  <div>
    <h2>System Configuration</h2>
    <p class="subtle">Create users dynamically, manage reporting lines, and keep workflow setup readable with shorter, better-scoped lists.</p>
  </div>
  <div class="role-chip">Admin View</div>
</section>

<section class="dashboard-grid admin-grid">
  <div class="panel">
    <div class="section-head"><strong>Localization Setup</strong></div>
    <div class="stack">
      <div class="info-row"><span>Company</span><strong><%= currentUser.company_name || 'Workspace' %></strong></div>
      <div class="info-row"><span>Registered Country</span><strong><%= companyCountry || currentUser.country || 'Configured' %></strong></div>
      <div class="info-row"><span>Base Currency</span><strong><%= currentUser.currency_code || 'USD' %></strong></div>
      <div class="info-row"><span>Active Users</span><strong><%= config.users.length %></strong></div>
    </div>
  </div>
  <div class="panel">
    <div class="section-head"><strong>Notifications</strong><span class="subtle">Top 5</span></div>
    <div class="log-list">
      <% notifications.forEach((notice) => { %>
        <div class="log-row">
          <span><strong><%= notice.title %></strong> - <%= notice.body %></span>
          <small><%= notice.created_at.toISOString().slice(0, 16).replace("T", " ") %></small>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="dashboard-grid admin-grid">
  <div class="panel">
    <div class="section-head"><strong>Workflow Engine</strong><span class="subtle">Top 5 categories</span></div>
    <div class="flow-summary-list">
      <% config.flows.forEach((flow) => { %>
        <article class="flow-summary-card">
          <div class="flow-summary-head">
            <div>
              <strong><%= flow.category_name %></strong>
              <p class="subtle">Threshold: <%= currentUser.currency_code || 'USD' %> <%= flow.soft_limit.toFixed(2) %></p>
            </div>
            <span class="badge badge-neutral">Limit</span>
          </div>
        </article>
      <% }) %>
      <% if (!config.flows.length) { %>
        <p class="subtle">No approval groups configured yet.</p>
      <% } %>
    </div>
  </div>
  <div class="panel">
    <div class="section-head"><strong>Create Users and Relationships</strong></div>
    <form action="/admin/users" method="post" class="stack">
      <div class="inline">
        <label>
          Full Name
          <input type="text" name="full_name" required />
        </label>
        <label>
          Email
          <input type="email" name="email" required />
        </label>
      </div>
      <div class="inline">
        <label>
          Temporary Password
          <input type="text" name="password" value="demo123" required />
        </label>
        <label>
          Role
          <select name="role_code" required>
            <% roles.forEach((role) => { %>
              <option value="<%= role.code %>"><%= role.name %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <div class="inline">
        <label>
          Department
          <select name="department_id">
            <option value="">Select department</option>
            <% departments.forEach((department) => { %>
              <option value="<%= department.id %>"><%= department.name %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Reporting Manager
          <select name="manager_user_id">
            <option value="">No manager</option>
            <% managers.forEach((manager) => { %>
              <option value="<%= manager.id %>"><%= manager.full_name %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <button type="submit">Create User</button>
    </form>
  </div>

  <div class="panel">
    <div class="section-head"><strong>Define Approval Group</strong></div>
    <form action="/admin/flows" method="post" class="stack">
      <label>
        Expense Type
        <select name="category_id" required>
          <% categories.forEach((category) => { %>
            <option value="<%= category.id %>"><%= category.name %></option>
          <% }) %>
        </select>
      </label>
      <div class="inline">
        <label>
          Step 1
          <select name="step_one_role" required>
            <% roles.forEach((role) => { %>
              <option value="<%= role.code %>"><%= role.name %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Step 2
          <select name="step_two_role" required>
            <% roles.forEach((role) => { %>
              <option value="<%= role.code %>"><%= role.name %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <label>
        Step 3
        <select name="step_three_role">
          <option value="">No third step</option>
          <% roles.forEach((role) => { %>
            <option value="<%= role.code %>"><%= role.name %></option>
          <% }) %>
        </select>
      </label>
      <button type="submit">Save Approval Rule</button>
    </form>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>User Access Matrix</strong><span class="subtle">Top 5 users</span></div>
  <div class="queue">
    <% config.users.forEach((user) => { %>
      <article class="queue-card">
        <div class="timeline-row">
          <strong><%= user.full_name %></strong>
          <span class="badge badge-neutral"><%= user.role_name %></span>
        </div>
        <div class="compact-meta">
          <span class="subtle"><%= user.email %></span>
          <span><strong><%= user.department_name || 'Not set' %></strong></span>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Workflow History</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% historyFeed.forEach((item) => { %>
      <div class="log-row">
        <span><strong><%= item.title %></strong> - <%= item.detail %></span>
        <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
      </div>
    <% }) %>
  </div>
</section>
<%- include("partials/app-shell-end") %>
