<%- include("partials/app-shell-start") %>
<section class="page-head">
  <div>
    <h2>CFO Shortcut Desk</h2>
    <p class="subtle">Review the highest-signal requests and risk flags quickly, without oversized tables or duplicated visual patterns.</p>
  </div>
  <div class="role-chip">CFO View</div>
</section>

<section class="stats-row">
  <div class="stat-card"><span>Total Claims</span><strong><%= summary.summary.total_claims || 0 %></strong></div>
  <div class="stat-card"><span>Approved</span><strong><%= summary.summary.approved_count || 0 %></strong></div>
  <div class="stat-card"><span>Rejected</span><strong><%= summary.summary.rejected_count || 0 %></strong></div>
  <div class="stat-card"><span>Spend</span><strong><%= summary.summary.total_spend || 0 %></strong></div>
</section>

<section class="panel">
  <div class="section-head"><strong>CFO Approval Queue</strong><span class="subtle">Top 5 pending items</span></div>
  <div class="queue">
    <% if (!reviewQueue.length) { %>
      <p class="subtle">No CFO shortcuts pending.</p>
    <% } %>
    <% reviewQueue.forEach((claim) => { %>
      <article class="queue-card">
        <div class="timeline-row">
          <strong><%= claim.employee_name %></strong>
          <span class="badge <%= claim.ai_summary === 'Authentic' ? 'badge-success' : 'badge-danger' %>"><%= claim.ai_summary %></span>
        </div>
        <div class="compact-meta">
          <span><strong><%= claim.category_name %></strong></span>
          <span><strong><%= claim.reported_currency %> <%= claim.amount %></strong></span>
          <span class="subtle">Status: <%= claim.status_label %></span>
        </div>
        <div class="actions compact-actions">
          <form action="/reviews/<%= claim.id %>/approve" method="post">
            <button type="submit">Approve</button>
          </form>
          <form action="/reviews/<%= claim.id %>/reject" method="post">
            <input type="hidden" name="comment" value="CFO did not approve" />
            <button type="submit" class="ghost">Reject</button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>CFO History</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% historyFeed.forEach((item) => { %>
      <div class="log-row">
        <span><strong><%= item.title %></strong> - <%= item.detail %></span>
        <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
      </div>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Top AI Flags</strong><span class="subtle">Top 5 highest risk</span></div>
  <% if (!summary.topFlags.length) { %>
    <p class="subtle">No flagged claims yet.</p>
  <% } %>
  <% summary.topFlags.forEach((flag) => { %>
    <div class="flag-row">
      <div><strong><%= flag.employee_name %></strong></div>
      <div class="flag-meta">
        <span class="badge badge-danger"><%= flag.ai_summary %></span>
        <strong><%= flag.company_currency %> <%= flag.converted_amount %></strong>
      </div>
    </div>
  <% }) %>
</section>

<section class="panel">
  <div class="section-head"><strong>Notifications</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% notifications.forEach((notice) => { %>
      <div class="log-row">
        <span><strong><%= notice.title %></strong> - <%= notice.body %></span>
        <small><%= notice.created_at.toISOString().slice(0, 16).replace("T", " ") %></small>
      </div>
    <% }) %>
  </div>
</section>
<%- include("partials/app-shell-end") %>
