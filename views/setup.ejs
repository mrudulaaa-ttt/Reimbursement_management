<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="setup-shell">
    <section class="setup-card">
      <p class="eyebrow">Step 1</p>
      <h1>Smart Company Setup</h1>
      <p class="subtle">Create a company profile with country-aware currency mapping and an admin contact for the demo.</p>

      <% if (message) { %><div class="flash success"><%= message %></div><% } %>
      <% if (error) { %><div class="flash error"><%= error %></div><% } %>

      <form action="/setup" method="post" class="stack">
        <label>
          Company Name
          <input type="text" name="company_name" required />
        </label>
        <label>
          Country
          <input type="text" name="country" placeholder="India, United States, Germany..." required />
        </label>
        <label>
          Admin Name
          <input type="text" name="admin_name" required />
        </label>
        <label>
          Admin Email
          <input type="email" name="admin_email" required />
        </label>
        <button type="submit">Create Demo Company</button>
      </form>
      <a href="/" class="back-link">Back to dashboard</a>
    </section>
  </main>
</body>
</html>
