<%- include("partials/app-shell-start") %>
<section class="page-head">
  <div>
    <h2>CEO Override Desk</h2>
    <p class="subtle">Final authority with a concise override queue and a cleaner view of recent executive actions.</p>
  </div>
  <div class="role-chip">CEO View</div>
</section>

<section class="panel">
  <div class="section-head"><strong>Override Queue</strong><span class="subtle">Top 5 eligible claims</span></div>
  <div class="queue">
    <% if (!ceoQueue.length) { %>
      <p class="subtle">No claims available for CEO override.</p>
    <% } %>
    <% ceoQueue.forEach((claim) => { %>
      <article class="queue-card">
        <div class="timeline-row">
          <strong><%= claim.employee_name %></strong>
          <span class="pill pill-<%= claim.status %>"><%= claim.status_label %></span>
        </div>
        <div class="compact-meta">
          <span><strong><%= claim.category_name %></strong></span>
          <span><strong><%= claim.company_currency %> <%= claim.converted_amount %></strong></span>
          <span class="subtle"><%= claim.reported_currency %> <%= claim.amount %></span>
        </div>
        <div class="actions compact-actions">
          <form action="/ceo/<%= claim.id %>/approve" method="post">
            <button type="submit">Force Approve</button>
          </form>
          <form action="/ceo/<%= claim.id %>/reject" method="post">
            <button type="submit" class="ghost">Force Reject</button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Override History</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% historyFeed.forEach((item) => { %>
      <div class="log-row">
        <span><strong><%= item.title %></strong> - <%= item.detail %></span>
        <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
      </div>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Notifications</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% notifications.forEach((notice) => { %>
      <div class="log-row">
        <span><strong><%= notice.title %></strong> - <%= notice.body %></span>
        <small><%= notice.created_at.toISOString().slice(0, 16).replace("T", " ") %></small>
      </div>
    <% }) %>
  </div>
</section>
<%- include("partials/app-shell-end") %>
