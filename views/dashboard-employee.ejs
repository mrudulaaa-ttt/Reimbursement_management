<%- include("partials/app-shell-start") %>
<section class="page-head">
  <div>
    <h2>My Reimbursements</h2>
    <p class="subtle">Submit a request, let the checks run, and stay on top of the latest updates without a crowded workspace.</p>
  </div>
  <div class="role-chip">Employee View</div>
</section>

<section class="dashboard-grid employee-grid">
  <div class="panel upload-panel">
    <div class="upload-icon">AI</div>
    <h3>Smart OCR Upload</h3>
    <p class="subtle">Build a clean request package with OCR checks, duplicate detection, and authenticity review before routing.</p>
    <% if (!managerConfigured) { %>
      <div class="flash error">Reporting manager is not assigned yet. Ask admin to define the employee-manager relationship.</div>
    <% } %>
    <form action="/claims" method="post" enctype="multipart/form-data" class="stack" data-claim-form>
      <label>
        Category
        <select name="category_id" data-request-category required>
          <% categories.forEach((category) => { %>
            <option value="<%= category.id %>"><%= category.name %></option>
          <% }) %>
        </select>
      </label>
      <div class="inline">
        <label>
          Amount
          <input type="number" step="0.01" name="amount" data-request-amount required />
        </label>
        <label>
          Expense Date
          <input type="date" name="expense_date" data-request-date required />
        </label>
      </div>
      <div class="inline">
        <label>
          Paid In Currency
          <select name="reported_currency" data-request-currency required>
            <option value="INR">INR</option>
            <option value="USD">USD</option>
            <option value="EUR">EUR</option>
            <option value="GBP">GBP</option>
            <option value="SGD">SGD</option>
          </select>
        </label>
        <label>
          Company Currency
          <input type="text" value="<%= companyCurrency %>" readonly />
        </label>
      </div>
      <label>
        Description
        <input type="text" name="description" data-request-description placeholder="Flights to Tech Conference" required />
      </label>
      <label>
        Remarks
        <input type="text" name="remarks" placeholder="Self-paid, urgent, conference code..." />
      </label>
      <label>
        Upload Documents
        <input type="file" name="receipt" data-request-file required />
      </label>
      <input type="hidden" name="submit_anyway" value="0" data-submit-anyway />
      <input type="hidden" name="precheck_complete" value="0" data-precheck-complete />
      <div class="request-preview">
        <div class="section-head">
          <strong>Formatted Request Preview</strong>
          <span class="subtle">Visible before submit</span>
        </div>
        <p data-request-preview>Category, amount, date, and uploaded document summary will appear here.</p>
      </div>
      <div class="validation-panel hidden" data-validation-panel>
        <div class="section-head">
          <strong>Validation Checks</strong>
          <span class="subtle" data-validation-summary>Review before routing to approval flow</span>
        </div>
        <div class="validation-list" data-validation-list></div>
        <label>
          Justification For Submit Anyway
          <textarea name="employee_justification" rows="3" placeholder="Explain why this should still proceed..." data-justification-input></textarea>
        </label>
        <div class="validation-actions">
          <button type="button" class="ghost" data-validation-edit>Cancel / Edit</button>
          <button type="button" data-validation-submit>Submit Anyway</button>
        </div>
      </div>
      <button type="submit" <%= managerConfigured ? '' : 'disabled' %>>Submit Request</button>
    </form>
  </div>

  <div class="panel recent-claims-panel">
    <div class="section-head">
      <strong>Recent Claims</strong>
      <span class="subtle">Top 5 latest entries</span>
    </div>
    <div class="timeline-track recent-claims-scroll">
      <% if (!employeeClaims.length) { %>
        <p class="subtle">No claims yet.</p>
      <% } %>
      <% employeeClaims.forEach((claim) => { %>
        <article class="timeline-item">
          <span class="dot dot-<%= claim.status %>"></span>
          <div class="timeline-card">
            <div class="timeline-row">
              <strong><%= claim.category_name %></strong>
              <span><%= claim.reported_currency %> <%= claim.amount %></span>
            </div>
            <p class="subtle">Submitted: <%= claim.expense_date.toISOString().slice(0, 10) %></p>
            <p class="timeline-status status-<%= claim.status %>"><%= claim.status_label %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="dashboard-grid employee-grid">
  <div class="panel">
    <div class="section-head">
      <strong>Approval Timeline</strong>
      <span class="subtle">Top 5 latest events</span>
    </div>
    <div class="log-list">
      <% if (!timeline.length) { %>
        <p class="subtle">Timeline will appear after your first submission.</p>
      <% } %>
      <% timeline.slice(0, 5).forEach((item) => { %>
        <div class="log-row">
          <span><%= item.event_label %></span>
          <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="panel">
    <div class="section-head"><strong>History and Notifications</strong><span class="subtle">Focused on recent activity</span></div>
    <div class="log-list">
      <% historyFeed.forEach((item) => { %>
        <div class="log-row">
          <span><strong><%= item.title %></strong> - <%= item.detail %></span>
          <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
        </div>
      <% }) %>
      <% notifications.forEach((notice) => { %>
        <div class="log-row">
          <span><strong><%= notice.title %></strong> - <%= notice.body %></span>
          <small><%= notice.created_at.toISOString().slice(0, 16).replace("T", " ") %></small>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<script src="/app.js"></script>
<%- include("partials/app-shell-end") %>
