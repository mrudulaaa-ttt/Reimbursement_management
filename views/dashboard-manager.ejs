<%- include("partials/app-shell-start") %>
<section class="page-head">
  <div>
    <h2>Manager Approvals</h2>
    <p class="subtle">Review the most important requests first with a smaller, cleaner queue and a concise team snapshot.</p>
  </div>
  <div class="role-chip">Manager View</div>
</section>

<section class="dashboard-grid employee-grid">
  <div class="panel">
    <div class="section-head"><strong>My Team</strong><span class="subtle">Top 5</span></div>
    <div class="log-list">
      <% teamMembers.forEach((member) => { %>
        <div class="log-row">
          <span><strong><%= member.full_name %></strong> - <%= member.department_name || 'Department' %></span>
          <small><%= member.email %></small>
        </div>
      <% }) %>
    </div>
  </div>
  <div class="panel">
    <div class="section-head"><strong>Review History</strong><span class="subtle">Top 5</span></div>
    <div class="log-list">
      <% historyFeed.forEach((item) => { %>
        <div class="log-row">
          <span><strong><%= item.title %></strong> - <%= item.detail %></span>
          <small><%= item.created_at ? item.created_at.toISOString().slice(0, 16).replace("T", " ") : "" %></small>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Approval Queue</strong><span class="subtle">Top 5 pending items</span></div>
  <div class="queue">
    <% if (!managerQueue.length) { %>
      <p class="subtle">No approval requests right now.</p>
    <% } %>
    <% managerQueue.forEach((claim) => { %>
      <article class="queue-card <%= claim.ai_summary.includes('Duplicate') ? 'queue-card-risk' : '' %>">
        <div class="timeline-row">
          <strong><%= claim.employee_name %></strong>
          <span class="pill pill-<%= claim.status %>"><%= claim.status_label %></span>
        </div>
        <div class="compact-meta">
          <span><strong><%= claim.category_name %></strong></span>
          <span><strong><%= claim.reported_currency %> <%= claim.amount %></strong></span>
          <span class="subtle"><%= claim.department_name || 'Department' %></span>
          <span class="badge <%= claim.ai_summary === 'Authentic' ? 'badge-success' : 'badge-danger' %>"><%= claim.ai_summary %></span>
        </div>
        <div class="actions compact-actions">
          <form action="/claims/<%= claim.id %>/approve" method="post">
            <button type="submit">Approve</button>
          </form>
          <form action="/claims/<%= claim.id %>/reject" method="post">
            <input type="hidden" name="comment" value="Disapproved by manager" />
            <button type="submit" class="ghost">Reject</button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="section-head"><strong>Notifications</strong><span class="subtle">Top 5</span></div>
  <div class="log-list">
    <% notifications.forEach((notice) => { %>
      <div class="log-row">
        <span><strong><%= notice.title %></strong> - <%= notice.body %></span>
        <small><%= notice.created_at.toISOString().slice(0, 16).replace("T", " ") %></small>
      </div>
    <% }) %>
  </div>
</section>
<%- include("partials/app-shell-end") %>
